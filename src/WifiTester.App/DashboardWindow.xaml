<Window x:Class="WifiTester.App.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WifiTester — Diagnostyka WiFi" Height="560" Width="680"
        Icon="/wifitester.ico"
        Background="{StaticResource Bg}"
        FontFamily="Segoe UI" FontSize="13">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Nagłówek TMA -->
        <Border Grid.Row="0" Background="{StaticResource HdrBg}" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Image Grid.Column="0" Source="/logotma.png" Height="34" Margin="0,0,16,0"
                       VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="WifiTester" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource HdrTxt}"/>
                    <TextBlock Text="Diagnostyka WiFi i internetu" FontSize="12"
                               Foreground="{StaticResource Muted}"/>
                </StackPanel>
                <TextBlock Grid.Column="2" Text="{Binding Version, Mode=OneWay}"
                           Foreground="{StaticResource HdrTxt}" VerticalAlignment="Center"
                           Margin="0,0,12,0" FontWeight="SemiBold"/>
                <Button Grid.Column="3" x:Name="SettingsButton" Content="⚙" FontSize="18"
                        Foreground="{StaticResource HdrTxt}" Background="Transparent"
                        BorderThickness="0" Cursor="Hand" Padding="6,0" ToolTip="Ustawienia"
                        Click="OnSettingsClick"/>
            </Grid>
        </Border>

        <!-- Pasek aktualizacji (widoczny tylko gdy dostępna) -->
        <Border Grid.Row="1" Background="{StaticResource UpdBarBg}" Padding="16,8"
                Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVis}, Mode=OneWay}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding UpdateText, Mode=OneWay}"
                           VerticalAlignment="Center" Foreground="#232A2D"/>
                <Button Grid.Column="1" Content="Zainstaluj" Background="{StaticResource UpdBtn}"
                        Foreground="#232A2D" BorderThickness="0" Padding="14,6" Cursor="Hand"
                        FontWeight="SemiBold" Click="OnUpdateClick"/>
            </Grid>
        </Border>

        <!-- Treść -->
        <Grid Grid.Row="2" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource Card}" CornerRadius="6" Padding="14">
                <StackPanel>
                    <TextBlock Text="Stan WiFi" FontSize="15" FontWeight="Bold" Margin="0,0,0,6"
                               Style="{StaticResource KartaTekst}"/>
                    <TextBlock Style="{StaticResource KartaTekst}"><Run Text="Status: "/><Run Text="{Binding Status, Mode=OneWay}"/></TextBlock>
                    <TextBlock Style="{StaticResource KartaTekst}"><Run Text="AP: "/><Run Text="{Binding Ap, Mode=OneWay}"/></TextBlock>
                    <TextBlock Style="{StaticResource KartaTekst}"><Run Text="Sygnał: "/><Run Text="{Binding Signal, Mode=OneWay}"/></TextBlock>
                    <TextBlock Style="{StaticResource KartaTekst}"><Run Text="Prędkość: "/><Run Text="{Binding LinkRate, Mode=OneWay}"/></TextBlock>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="{StaticResource Card}" CornerRadius="6" Padding="14" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="Latencja" FontSize="15" FontWeight="Bold" Margin="0,0,0,6"
                               Style="{StaticResource KartaTekst}"/>
                    <ItemsControl ItemsSource="{Binding Latencies}"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Background="{StaticResource Card}" CornerRadius="6" Padding="14" Margin="0,12,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" FontSize="15" FontWeight="Bold" Margin="0,0,0,6"
                               Style="{StaticResource KartaTekst}">
                        <Run Text="Defekty ("/><Run Text="{Binding DefectCount, Mode=OneWay}"/><Run Text=")"/>
                    </TextBlock>
                    <ListBox ItemsSource="{Binding Defects}" Background="Transparent" BorderThickness="0"/>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
